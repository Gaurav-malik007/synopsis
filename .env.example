# Google Gemini API Key
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Google Sheets Configuration (Optional but Recommended)
# Follow the setup guide in GOOGLE_SHEETS_SETUP.md to enable Google Sheets sync

# Google Sheets URL - The full URL to your registrations spreadsheet
# Example: https://docs.google.com/spreadsheets/d/1a2b3c4d5e6f7g8h9i0j/edit
GOOGLE_SHEET_URL=

# Google Service Account Credentials File
# Path to your Google service account credentials JSON
# Default: credentials.json (in the same directory as web_app.py)
GOOGLE_SHEET_CREDENTIALS=credentials.json
